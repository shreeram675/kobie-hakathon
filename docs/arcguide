def generate_pdf(output_path: Path = OUTPUT_PDF) -> Path:
    output_path.parent.mkdir(parents=True, exist_ok=True)
    styles = build_styles()
    buffer = BytesIO()
    doc = SimpleDocTemplate(
        buffer,
        pagesize=A4,
        rightMargin=1.25 * cm,
        leftMargin=1.25 * cm,
        topMargin=1.2 * cm,
        bottomMargin=1.2 * cm,
        title="Kobie Phase 2 ArcGuide Updated",
        author="Innovative Iterators",
    )
    story = build_story(styles)
    doc.build(story, onFirstPage=page_footer, onLaterPages=page_footer)
    output_path.write_bytes(buffer.getvalue())
    return output_path


def main() -> None:
    parser = argparse.ArgumentParser(description="Generate or print the Kobie Phase 2 ArcGuide.")
    parser.add_argument(
        "--print-reference",
        action="store_true",
        help="Print the searchable AG-* development reference instead of generating the PDF.",
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=OUTPUT_PDF,
        help="Output PDF path. Defaults to Kobie_Phase2_ArcGuide_Updated.pdf in the project root.",
    )
    args = parser.parse_args()

    if args.print_reference:
        print(AGENT_REFERENCE.strip())
        return

    pdf_path = generate_pdf(args.output)
    print(f"Generated {pdf_path}")


if __name__ == "__main__":
    main()
