def esc(text: object) -> str:
    value = str(text)
    return (
        value.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace("\n", "<br/>")
    )


def para(text: str, styles, style_name: str = "BodyCustom") -> Paragraph:
    return Paragraph(esc(text), styles[style_name])


def heading(text: str, styles, level: int = 1) -> Paragraph:
    return Paragraph(esc(text), styles["H1Custom" if level == 1 else "H2Custom"])


def bullets(items: Iterable[str], styles) -> ListFlowable:
    return ListFlowable(
        [ListItem(para(item, styles), leftIndent=12) for item in items],
        bulletType="bullet",
        leftIndent=14,
        bulletFontSize=7,
    )


def code_block(text: str, styles) -> Paragraph:
    return Paragraph(esc(text), styles["CodeCustom"])


def table(data, styles, col_widths=None, header=True, font_size=7.3):
    wrapped = []
    for row in data:
        wrapped.append([Paragraph(esc(cell), styles["SmallCustom"]) for cell in row])
    t = Table(wrapped, colWidths=col_widths, hAlign="LEFT", repeatRows=1 if header else 0)
    commands = [
        ("GRID", (0, 0), (-1, -1), 0.35, colors.HexColor("#CCD3DA")),
        ("VALIGN", (0, 0), (-1, -1), "TOP"),
        ("LEFTPADDING", (0, 0), (-1, -1), 5),
        ("RIGHTPADDING", (0, 0), (-1, -1), 5),
        ("TOPPADDING", (0, 0), (-1, -1), 4),
        ("BOTTOMPADDING", (0, 0), (-1, -1), 4),
        ("FONTSIZE", (0, 0), (-1, -1), font_size),
    ]
    if header:
        commands.extend(
            [
                ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#203040")),
                ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
                ("FONTNAME", (0, 0), (-1, 0), "Helvetica-Bold"),
            ]
        )
    t.setStyle(TableStyle(commands))
    return t


def add_section(story, styles, section: Section):
    story.append(heading(section.title, styles))
    for paragraph in section.body:
        story.append(para(paragraph, styles))
    if section.bullets:
        story.append(bullets(section.bullets, styles))
    story.append(Spacer(1, 0.12 * cm))


def page_footer(canvas, doc):
    canvas.saveState()
    canvas.setFont("Helvetica", 7)
    canvas.setFillColor(colors.HexColor("#607080"))
    canvas.drawString(1.35 * cm, 0.8 * cm, "Innovative Iterators - Phase 2 Technical ArcGuide")
    canvas.drawRightString(19.5 * cm, 0.8 * cm, f"Page {doc.page}")
    canvas.restoreState()


