# ============================================================
# Kobie environment template
# Copy to .env and fill in the keys you have. Stage-specific keys
# are optional: any blank stage key falls back to the shared key
# for that provider (GEMINI_API_KEY or GROQ_API_KEY).
# ============================================================

# ---- Input validator (any OpenAI-compatible endpoint) ----
INPUT_VERIFIER_API_BASE=https://api.groq.com/openai/v1
INPUT_VERIFIER_MODEL=llama-3.3-70b-versatile
INPUT_VERIFIER_API_KEY=your_input_verifier_key

# ---- Shared provider keys (fallbacks for all stages below) ----
GEMINI_API_KEY=your_gemini_key
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GROQ_API_KEY=your_groq_key

# ---- Tavily search (retrieval) ----
TAVILY_API_KEY=your_tavily_key
TAVILY_API_BASE=https://api.tavily.com

# ---- Firecrawl scraping ----
FIRECRAWL_API_KEY=your_firecrawl_key
FIRECRAWL_API_BASE=https://api.firecrawl.dev

# ---- Per-purpose API keys (optional overrides) ----
# Query generation (Gemini)
QUERY_GENERATOR_API_KEY=
QUERY_GENERATOR_API_BASE=
QUERY_GENERATOR_MODEL=gemini-2.5-flash
QUERY_GENERATOR_FALLBACK_MODELS=gemini-2.5-flash-lite

# Structured extraction (Gemini)
EXTRACTION_API_KEY=
EXTRACTION_API_BASE=
# EXTRACTION_MODEL=gemini-2.5-flash
EXTRACTION_FALLBACK_MODELS=gemini-2.5-flash-lite

# Verification / confidence scoring (Gemini)
VERIFICATION_API_KEY=
VERIFICATION_API_BASE=

# Narration / brief generation (Gemini)
NARRATION_API_KEY=
NARRATION_API_BASE=

# Post-brief converse Q&A (Groq)
CONVERSE_API_KEY=
# CONVERSE_MODEL=llama-3.1-70b-versatile

# Adversarial debate engine (Groq)
DEBATE_API_KEY=
# DEBATE_MODEL=llama3-70b-8192

# ---- Pipeline cost/budget knobs ----
MAX_FIRECRAWL_URLS=12
MAX_EXTRACTION_CHUNKS=30
EXTRACTION_BATCH_WORDS=4000
MIN_EXTRACTION_CHUNK_SCORE=2
GEMINI_EXTRACTION_CONCURRENCY=2
